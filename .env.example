# Copy to .env.local and fill in values. See README.md.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Logo.dev publishable key (pk_…) — used for employer logos on home/stats
# https://www.logo.dev/docs/integrations/nextjs
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# PostHog — project token from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
